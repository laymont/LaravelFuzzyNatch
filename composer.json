{
    "name": "laymont/laravel-fuzzy-match",
    "description": "Laravel package for fuzzy matching (string similarity) using Levenshtein, SimilarText, and Jaro-Winkler algorithms",
    "keywords": [
        "laravel",
        "fuzzy",
        "match",
        "similarity",
        "levenshtein",
        "jaro-winkler"
    ],
    "license": "MIT",
    "type": "library",
    "authors": [
        {
            "name": "Laymont",
            "email": "info@laymont.com"
        }
    ],
    "require": {
        "php": "^8.2",
        "illuminate/support": "^13.0"
    },
    "require-dev": {
        "orchestra/testbench": "^10.0",
        "pestphp/pest": "^3.0",
        "laravel/pint": "^1.0"
    },
    "autoload": {
        "psr-4": {
            "Laymont\\FuzzyMatch\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Laymont\\FuzzyMatch\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Laymont\\FuzzyMatch\\FuzzyMatchServiceProvider"
            ],
            "aliases": {
                "FuzzyMatch": "Laymont\\FuzzyMatch\\Facades\\FuzzyMatch"
            }
        }
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
